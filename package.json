{
  "name": "data-insight-pro",
  "version": "1.0.0",
  "description": "AI-powered data analysis tool for product managers",
  "main": "dist-main/main/index.js",
  "author": "Terry <terry@ioty.io>",
  "license": "MIT",
  "scripts": {
    "dev": "npm run dev:renderer & npm run dev:main",
    "dev:renderer": "vite --port 5173 --strictPort",
    "dev:main": "tsc -p tsconfig.main.json && electron .",
    "build": "npm run build:renderer && npm run build:main",
    "build:renderer": "vite build",
    "build:main": "tsc -p tsconfig.main.json",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:win": "npm run build && electron-builder --win"
  },
  "build": {
    "appId": "com.datainsight.pro",
    "productName": "DeciFlow",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist-main/**/*",
      "dist-renderer/**/*",
      "resources/**/*"
    ],
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "category": "public.app-category.developer-tools"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.27",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "electron-store": "^11.0.2",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.8.0",
    "mongodb": "^7.1.1",
    "mysql2": "^3.22.0",
    "pg": "^8.20.0",
    "postcss": "^8.5.9",
    "postcss-nesting": "^14.0.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "recharts": "^3.8.1",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^3.4.19",
    "vite": "^8.0.8",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "typescript": "^6.0.2"
  }
}
