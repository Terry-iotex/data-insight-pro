# Apple Developer 配置（用于 Mac App Store 和公证）
# 获取方式：https://appleid.apple.com
APPLE_ID=your-apple-id@email.com
# App-specific password（在 appleid.apple.com 生成）
APPLE_ID_PASSWORD=xxxx-xxxx-xxxx-xxxx
# Team ID（在 Apple Developer 后台查看）
APPLE_TEAM_ID=XXXXXXXXXX

# Microsoft Store 配置
# 获取方式：https://partner.microsoft.com/dashboard
MICROSOFT_STORE_TENANT_ID=your-tenant-id
MICROSOFT_STORE_CLIENT_ID=your-client-id
MICROSOFT_STORE_CLIENT_SECRET=your-client-secret
